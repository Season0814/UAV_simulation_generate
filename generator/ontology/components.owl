<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns:a4="http://season.ai4sim/ontology#">

  <owl:Ontology rdf:about="http://season.ai4sim/ontology/components"/>

  <owl:Class rdf:about="http://season.ai4sim/ontology#Template"/>
  <owl:Class rdf:about="http://season.ai4sim/ontology#FrameworkTemplate">
    <rdfs:subClassOf rdf:resource="http://season.ai4sim/ontology#Template"/>
  </owl:Class>
  <owl:Class rdf:about="http://season.ai4sim/ontology#ComponentTemplate">
    <rdfs:subClassOf rdf:resource="http://season.ai4sim/ontology#Template"/>
  </owl:Class>
  <owl:Class rdf:about="http://season.ai4sim/ontology#TemplateSlot"/>
  <owl:Class rdf:about="http://season.ai4sim/ontology#TemplateVariable"/>
  <owl:Class rdf:about="http://season.ai4sim/ontology#DefaultBinding"/>

  <owl:ObjectProperty rdf:about="http://season.ai4sim/ontology#hasSlot">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#Template"/>
    <rdfs:range rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://season.ai4sim/ontology#usesTemplate">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
    <rdfs:range rdf:resource="http://season.ai4sim/ontology#Template"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://season.ai4sim/ontology#hasVariable">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#Template"/>
    <rdfs:range rdf:resource="http://season.ai4sim/ontology#TemplateVariable"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://season.ai4sim/ontology#hasDefaultBinding">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
    <rdfs:range rdf:resource="http://season.ai4sim/ontology#DefaultBinding"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#sourceFile">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#Template"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#xmlRootTag">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#Template"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#slotName">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#placeholder">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#contextLabel">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateSlot"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#varName">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#TemplateVariable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#bindingKey">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#DefaultBinding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://season.ai4sim/ontology#bindingValue">
    <rdfs:domain rdf:resource="http://season.ai4sim/ontology#DefaultBinding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

